    name = "ecma-119",
    srcs = glob(["src/**/*.rs"]),
    features = select({
        "prelude//os:none": [],
        "DEFAULT": ["build"]
    }),
    deps = _DEPS,
    tests = [":ecma-119_unittests", ":ecma-119_roundtrip"],
    visibility = ["PUBLIC"]
)

