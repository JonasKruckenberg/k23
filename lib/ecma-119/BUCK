    name = "ecma-119_unittests",
    srcs = glob(["src/**/*.rs"]),
    features = ["build"],
    target_compatible_with = [host_configuration.os, host_configuration.cpu],
    visibility = ["PUBLIC"],
    deps = _DEPS
)

